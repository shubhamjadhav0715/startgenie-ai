OPENAI_API_KEY=your_api_key_here
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_BLUEPRINT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
BLUEPRINT_GENERATE_VISUAL=true

# App URLs
APP_BASE_URL=http://localhost:5173

# Auth
JWT_SECRET=change_me
# Keep false during development if SMTP is not configured.
EMAIL_VERIFICATION_REQUIRED=false

# Email (SMTP). If not set, the backend logs verification links to console.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="StartGenie AI <your_email@gmail.com>"

# Google login
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# RAG tuning
RAG_CHAT_TOP_K=4
RAG_MIN_SCORE=0.2

# RAG ingestion (official public sources)
RAG_INGEST_MAX_PAGES_PER_HOST=10
RAG_INGEST_MAX_DEPTH=2
RAG_INGEST_MIN_TEXT_CHARS=700
