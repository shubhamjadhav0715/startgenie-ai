# MongoDB Atlas
# Example:
# MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority"
MONGODB_URI=

# OpenAI
# Put your real key in backend/.env (never commit it).
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_BLUEPRINT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
BLUEPRINT_GENERATE_VISUAL=true

# App URLs
APP_BASE_URL=http://localhost:5173

# Auth
JWT_SECRET=change_me
# If true, email/password login is blocked until verified.
# If SMTP is not configured, backend prints the verification link to the backend console.
EMAIL_VERIFICATION_REQUIRED=true

# Email (SMTP).
# If not set, the backend logs verification links to console and email export will return an error.
# Gmail note: use a Google "App Password" (not your normal Gmail password).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Google login
GOOGLE_CLIENT_ID=98806031558-rotojenfl44rqrg6sgbabi9toci4arju.apps.googleusercontent.com

# RAG tuning
RAG_CHAT_TOP_K=4
RAG_MIN_SCORE=0.2

# RAG ingestion (official public sources)
RAG_INGEST_MAX_PAGES_PER_HOST=10
RAG_INGEST_MAX_DEPTH=2
RAG_INGEST_MIN_TEXT_CHARS=700
